{
  "name": "balencia-server",
  "version": "1.0.0",
  "description": "Balencia API Server - Advanced Node.js Backend",
  "main": "dist/server/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server/src/index.js",
    "start:prod": "NODE_ENV=production node dist/server/src/index.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "node -e \"require('fs').cpSync('src/mails','dist/server/src/mails',{recursive:true})\"",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --runInBand",
    "db:setup": "tsx src/database/setup.ts",
    "db:migrate": "tsx src/database/run-migrations.ts",
    "db:migrate:auto": "tsx src/scripts/migrate.ts migrate",
    "db:migrate:verify": "tsx src/scripts/migrate.ts verify",
    "db:migrate:health-metrics": "tsx src/database/run-daily-health-metrics-migration.ts",
    "db:migrate:chat": "tsx src/database/migrate-chat-tables.ts",
    "db:migrate:schedule": "tsx src/database/migrate-schedule-tables.ts",
    "db:migrate:goal-tracking": "tsx src/database/migrate-goal-daily-tracking.ts",
    "db:migrate:breathing-tests": "tsx src/database/migrate-breathing-tests.ts",
    "db:migrate:emotional-checkin": "tsx src/database/migrate-emotional-checkin.ts",
    "db:migrate:activity-status": "tsx src/database/migrate-activity-status-history.ts",
    "db:migrate:activity-automation": "tsx src/database/run-activity-automation-migration.ts",
    "db:migrate:schedule-automation": "tsx src/database/run-schedule-automation-migration.ts",
    "db:migrate:contact": "tsx src/database/migrate-contact-submissions.ts",
    "db:migrate:all": "tsx src/database/run-migration.ts add-all-new-tables.sql",
    "db:migrate:newsletter": "tsx src/database/run-migration.ts add-newsletter-subscriptions.sql",
    "db:migrate:testimonials": "tsx src/database/run-migration.ts add-testimonials-table.sql",
    "db:migrate:coaching-profiles": "tsx src/database/run-migration.ts add-user-coaching-profiles.sql",
    "db:migrate:classifications": "tsx src/database/run-migration.ts add-user-classification-tables.sql",
    "db:migrate:interventions": "tsx src/database/run-migration.ts add-user-interventions.sql",
    "db:migrate:contradictions": "tsx src/database/run-migration.ts add-cross-pillar-contradictions.sql",
    "db:migrate:gamification": "tsx src/database/run-migration.ts add-gamification-upgrade-tables.sql",
    "db:migrate:view-once": "tsx src/database/run-migration.ts add-view-once-messages.sql",
    "db:migrate:exercises": "tsx src/database/run-migration.ts add-exercise-ingestion-columns.sql",
    "db:migrate:roles": "tsx src/database/run-role-permissions-migration.ts",
    "db:migrate:visitors": "tsx src/database/run-migration.ts add-visitor-visits.sql",
    "db:migrate:subscriptions": "tsx src/database/run-migration.ts add-subscription-tables.sql",
    "db:migrate:obstacles": "tsx src/database/run-migration.ts 20260416000000_goal_obstacles.sql",
    "db:migrate:reconnections": "tsx src/database/run-migration.ts 20260417000000_goal_reconnections.sql",
    "db:seed:questions": "tsx src/database/seed-assessment-questions.ts",
    "db:seed:community": "tsx src/database/seed-community-group.ts",
    "db:seed:blogs": "tsx src/database/seed-blogs.ts",
    "db:seed:subscription-plans": "tsx src/database/seed-subscription-plans.ts",
    "db:migrate:blog-image": "tsx src/database/migrate-blog-featured-image.ts",
    "migrate:embeddings": "tsx src/database/migrate-embeddings.ts",
    "migrate:embeddings:status": "tsx src/database/migrate-embeddings.ts status",
    "migrate:embeddings:retry": "tsx src/database/migrate-embeddings.ts retry"
  },
