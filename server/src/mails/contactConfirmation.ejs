<%# Contact Form Submission Confirmation Email Template %>
<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
  <title>We Received Your Message - yHealth</title>
  <style>
    html, body { margin: 0 !important; padding: 0 !important; height: 100% !important; width: 100% !important; }
    * { -ms-text-size-adjust: 100%; -webkit-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt !important; mso-table-rspace: 0pt !important; }
    table { border-spacing: 0 !important; border-collapse: collapse !important; table-layout: fixed !important; margin: 0 auto !important; }
    img { -ms-interpolation-mode: bicubic; }
    a { text-decoration: none; }
    @media screen and (max-width: 600px) {
      .email-container { width: 100% !important; margin: auto !important; }
      .mobile-padding { padding: 20px !important; }
    }
  </style>
</head>
<body width="100%" style="margin: 0; padding: 0 !important; mso-line-height-rule: exactly; background-color: #F9FAFB;">
  <div style="display: none; font-size: 1px; line-height: 1px; max-height: 0px; max-width: 0px; opacity: 0; overflow: hidden; mso-hide: all;">
    Thank you for contacting yHealth, <%= name %>! We've received your message and will get back to you within 24 hours.
  </div>

  <center role="article" aria-roledescription="email" lang="en" style="width: 100%; background-color: #F9FAFB;">
    <table align="center" role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="margin: auto;" class="email-container">
      <!-- Header with Logo -->
      <tr>
        <td style="padding: 30px 0; text-align: center;">
          <div style="font-size: 32px; font-weight: 800; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; letter-spacing: -1px;">
            <span style="color: #6366F1;">y</span><span style="color: #1F2937;">Health</span>
          </div>
          <div style="font-size: 12px; color: #6B7280; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; margin-top: 4px; text-transform: uppercase; letter-spacing: 2px;">
            Your AI Life Coach
          </div>
        </td>
      </tr>

      <!-- Main Content Card -->
      <tr>
        <td style="padding: 0 20px;">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #FFFFFF; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);">
            <!-- Gradient Top Bar -->
            <tr>
              <td style="height: 6px; background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A855F7 100%); border-radius: 16px 16px 0 0;"></td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 40px 40px 20px 40px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;" class="mobile-padding">
                <div style="text-align: center; margin-bottom: 32px;">
                  <div style="font-size: 64px; margin-bottom: 16px;">✉️</div>
                  <h1 style="margin: 0 0 8px 0; font-size: 28px; font-weight: 700; color: #1F2937; line-height: 1.3;">
                    We Received Your Message!
                  </h1>
                  <p style="margin: 0; font-size: 18px; color: #6B7280;">
                    Thank you for reaching out, <%= name %>
                  </p>
                </div>

                <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 26px; color: #4B5563;">
                  We've successfully received your contact form submission and our support team has been notified. We're committed to providing you with the best possible assistance.
                </p>

                <!-- Submission Details Card -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 32px 0; background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%); border-radius: 12px; padding: 24px;">
                  <tr>
                    <td>
                      <p style="margin: 0 0 16px 0; font-weight: 600; color: #1F2937; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">
                        Your Submission Details
                      </p>

                      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                        <tr>
                          <td style="padding: 8px 0; border-bottom: 1px solid rgba(99, 102, 241, 0.2);">
                            <p style="margin: 0; font-size: 13px; color: #6B7280; font-weight: 500;">Subject</p>
                            <p style="margin: 4px 0 0 0; font-size: 15px; color: #1F2937; font-weight: 600;"><%= subject %></p>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 12px 0;">
                            <p style="margin: 0; font-size: 13px; color: #6B7280; font-weight: 500;">Message</p>
                            <p style="margin: 4px 0 0 0; font-size: 15px; color: #1F2937; line-height: 22px; white-space: pre-wrap;"><%= message %></p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Response Time Promise -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 32px 0;">
                  <tr>
                    <td style="padding: 20px; background: #F3F4F6; border-radius: 12px; border-left: 4px solid #6366F1;">
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                        <tr>
                          <td width="48" valign="top" style="padding-right: 16px;">
                            <div style="width: 48px; height: 48px; background: #6366F1; border-radius: 12px; text-align: center; line-height: 48px; font-size: 24px;">⏱️</div>
                          </td>
                          <td valign="top">
                            <p style="margin: 0 0 4px 0; font-weight: 600; color: #1F2937; font-size: 15px;">Quick Response Guarantee</p>
                            <p style="margin: 0; color: #6B7280; font-size: 14px; line-height: 20px;">Our dedicated support team responds to all inquiries within <strong>24 hours</strong>. We'll get back to you as soon as possible!</p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- What Happens Next -->
                <div style="margin: 32px 0; padding: 24px; background: #F9FAFB; border-radius: 12px;">
                  <h2 style="margin: 0 0 16px 0; font-size: 18px; font-weight: 600; color: #1F2937;">What happens next?</h2>

                  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                    <tr>
                      <td style="padding: 12px 0; border-bottom: 1px solid #E5E7EB;">
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                          <tr>
                            <td width="32" valign="top">
                              <div style="width: 24px; height: 24px; background: #6366F1; border-radius: 50%; text-align: center; line-height: 24px; color: #FFFFFF; font-weight: 600; font-size: 12px;">1</div>
                            </td>
                            <td valign="top">
                              <p style="margin: 0; font-size: 14px; color: #4B5563; line-height: 20px;">Our team reviews your message and assigns it to the appropriate specialist</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding: 12px 0; border-bottom: 1px solid #E5E7EB;">
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                          <tr>
                            <td width="32" valign="top">
                              <div style="width: 24px; height: 24px; background: #6366F1; border-radius: 50%; text-align: center; line-height: 24px; color: #FFFFFF; font-weight: 600; font-size: 12px;">2</div>
                            </td>
                            <td valign="top">
                              <p style="margin: 0; font-size: 14px; color: #4B5563; line-height: 20px;">We'll send you a personalized response via email</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding: 12px 0;">
                        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                          <tr>
                            <td width="32" valign="top">
                              <div style="width: 24px; height: 24px; background: #6366F1; border-radius: 50%; text-align: center; line-height: 24px; color: #FFFFFF; font-weight: 600; font-size: 12px;">3</div>
                            </td>
                            <td valign="top">
                              <p style="margin: 0; font-size: 14px; color: #4B5563; line-height: 20px;">If needed, we'll follow up to ensure your issue is fully resolved</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </div>

                <!-- CTA Button -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 32px 0;">
                  <tr>
                    <td align="center">
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td style="border-radius: 12px; background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A855F7 100%);">
                            <a href="<%= typeof dashboardUrl !== 'undefined' ? dashboardUrl : '#' %>" target="_blank" style="display: inline-block; padding: 16px 40px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 600; color: #FFFFFF; text-decoration: none; border-radius: 12px;">
                              Visit Dashboard
                            </a>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Secondary Content -->
                <div style="font-size: 14px; line-height: 22px; color: #6B7280; margin-top: 24px; padding-top: 24px; border-top: 1px solid #E5E7EB;">
                  <p style="margin: 0 0 8px 0; font-weight: 600; color: #1F2937;">
                    Need immediate assistance?
                  </p>
                  <p style="margin: 0; font-size: 14px;">
                    If your inquiry is urgent, please call us directly or reach out through our live chat. For general questions, check out our <a href="<%= typeof helpUrl !== 'undefined' ? helpUrl : '#' %>" style="color: #6366F1; font-weight: 600;">help center</a>.
                  </p>
                </div>
              </td>
            </tr>

            <!-- Footer inside card -->
            <tr>
              <td style="padding: 20px 40px 40px 40px;" class="mobile-padding">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <tr>
                    <td style="padding-top: 24px; border-top: 1px solid #E5E7EB;">
                      <p style="margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; color: #6B7280;">
                        This is an automated confirmation email. Please do not reply to this message. Our team will contact you directly at <strong><%= email %></strong>.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td style="padding: 30px 20px;">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
            <tr>
              <td style="text-align: center;">
                <p style="margin: 0 0 8px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; color: #6B7280;">
                  yHealth by Xyric Solutions
                </p>
                <p style="margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; color: #9CA3AF;">
                  Your AI Life Coach - Powered by invisible intelligence
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </center>
</body>
</html>
